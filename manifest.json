{
    "manifest_version": 2,
    "name": "Your Extension Name",
    "version": "1.0",
    "background": {
      "scripts": ["src/background.js"]
    },
    "permissions": [
      "runtime"
    ],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["src/content.js"]
      }
    ]
}